# Relay configuration — copy to `config.toml` and adjust.
# Path can be overridden with the RELAY_CONFIG environment variable.
#
# Authentication is MANDATORY: the broker refuses to boot unless an [auth]
# section is present, and every CONNECT must carry a valid JWT. There is no
# open / anonymous mode.

# TCP listener for native MQTT clients (Rust, Go, Java backends).
tcp_addr = "0.0.0.0:1883"

# WebSocket listener for browser / mobile clients (MQTT-over-WebSocket).
ws_addr = "0.0.0.0:8083"

# On-disk store directory. When set, retained messages, durable sessions and
# their in-flight queues survive restarts (an embedded `redb` file is created
# inside). Leave unset for in-memory only.
# Use a TOML literal string (single quotes) for Windows paths.
# data_dir = 'C:\relay-data'
# data_dir = "/var/lib/relay"

# Redelivery / dead-letter policy for unacknowledged QoS 1/2 messages.
# Total delivery attempts before a message is dead-lettered (1 = no retry).
max_delivery_attempts = 5
# Base back-off between attempts, in seconds (doubles each attempt, capped below).
retry_base_secs = 5
# Upper bound on the redelivery back-off, in seconds.
retry_max_secs = 60

# Replayable event log: every published application message is journalled with a
# global offset (requires data_dir). A client replays from an offset by
# publishing to `$replay/{from_offset}/{topic_filter}`. This caps the log size;
# the oldest events are pruned beyond it. Set to 0 to disable the log (no replay).
event_log_max = 100000

# Secure MQTT (mqtts). TLS is enabled only when tls_cert AND tls_key are set;
# tls_addr defaults to 0.0.0.0:8883 (the IANA mqtts port) if omitted. Point them
# at a PEM certificate chain and PEM private key.
# tls_addr = "0.0.0.0:8883"
# tls_cert = '/etc/relay/cert.pem'
# tls_key  = '/etc/relay/key.pem'

# Embedded monitoring dashboard (built into the broker, no separate service).
# Set an address to enable it: `/` serves a live HTML page, `/stats` returns
# JSON (clients, subscriptions, retained, dead-letters, event-log offset).
# http_addr = "127.0.0.1:8080"

# Authentication + topic ACL (MANDATORY). The [auth] section below is required:
# without it the broker refuses to start. Every CONNECT must carry a valid JWT,
# sent as the MQTT *password* (username is ignored). A CONNECT without a valid
# token is rejected with NotAuthorized.
[auth]
# HS256 shared secret used to verify the JWT signature.
jwt_secret = "change-me-shared-secret-min-32-bytes"
# Claim used as the principal identity (and as {sub} in ACL templates).
identity_claim = "sub"
# Claim holding the principal's roles (a JSON array of strings).
roles_claim = "roles"

# ACL rules. A client receives the union of every rule whose `role` matches
# one of its token roles (`role = "*"` matches any authenticated client).
# Patterns may use `{claim}` placeholders, substituted from the token — e.g.
# `{sub}` becomes the identity. A pattern referencing a missing claim grants
# nothing (fail closed). Publish is checked against the concrete topic;
# subscribe requires the requested filter to be *subsumed* by an allowed
# pattern (a client can't widen its reach with `#`).

# Drive users: only their own Drive subtree (requires the `drive` role).
[[auth.acl]]
role = "drive"
publish   = ["drive/{sub}/#"]
subscribe = ["drive/{sub}/#"]

# Admins: the whole Drive tree + the dead-letter stream.
[[auth.acl]]
role = "drive_admin"
publish   = ["drive/#"]
subscribe = ["drive/#", "$dlq/#"]
