# Relay configuration — copy to `config.toml` and adjust.
# Path can be overridden with the RELAY_CONFIG environment variable.

# TCP listener for native MQTT clients (Rust, Go, Java backends).
tcp_addr = "0.0.0.0:1883"

# WebSocket listener for browser / mobile clients (MQTT-over-WebSocket).
ws_addr = "0.0.0.0:8083"

# On-disk store directory. When set, retained messages, durable sessions and
# their in-flight queues survive restarts (an embedded `redb` file is created
# inside). Leave unset for in-memory only.
# Use a TOML literal string (single quotes) for Windows paths.
# data_dir = 'C:\relay-data'
# data_dir = "/var/lib/relay"

# Redelivery / dead-letter policy for unacknowledged QoS 1/2 messages.
# Total delivery attempts before a message is dead-lettered (1 = no retry).
max_delivery_attempts = 5
# Base back-off between attempts, in seconds (doubles each attempt, capped below).
retry_base_secs = 5
# Upper bound on the redelivery back-off, in seconds.
retry_max_secs = 60

# Replayable event log: every published application message is journalled with a
# global offset (requires data_dir). A client replays from an offset by
# publishing to `$replay/{from_offset}/{topic_filter}`. This caps the log size;
# the oldest events are pruned beyond it. Set to 0 to disable the log (no replay).
event_log_max = 100000

# Secure MQTT (mqtts). TLS is enabled only when tls_cert AND tls_key are set;
# tls_addr defaults to 0.0.0.0:8883 (the IANA mqtts port) if omitted. Point them
# at a PEM certificate chain and PEM private key.
# tls_addr = "0.0.0.0:8883"
# tls_cert = '/etc/relay/cert.pem'
# tls_key  = '/etc/relay/key.pem'
